<Window x:Class="PersonManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Person Manager" Height="450" Width="450"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox x:Name="PeopleListBox" Grid.Row="0" Margin="0,0,0,10" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="AddMultipleBtn" Content="Add (Modeless)" Width="120" Margin="5" Click="AddMultipleBtn_Click"/>
            <Button x:Name="AddSingleBtn" Content="Add Single (Modal)" Width="120" Margin="5" Click="AddSingleBtn_Click"/>
            <Button x:Name="EditSelectedBtn" Content="Edit Selected" Width="120" Margin="5" Click="EditSelectedBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>